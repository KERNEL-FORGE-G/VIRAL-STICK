# ============================
# Node.js / Backend / Web
# ============================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Variables d'environnement (clés API, secrets)
.env
.env copy.example
.env.local
.env.*.local
backend/.env

# Configuration Firebase (Autorisé explicitement pour le déploiement)
!backend/firebase-service-account.json
# Backup files (Firebase service account backups are sensitive)
*.BAK
*.bak
backend/firebase-service-account.json.*

# Builds
dist/
build/
web/build/
web/dist/

