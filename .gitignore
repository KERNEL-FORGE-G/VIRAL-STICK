mobile/android/build/
mobile/android/local.properties
mobile/android/.idea/
mobile/android/*.iml
mobile/android/captures/
mobile/android/.externalNativeBuild/
mobile/android/.cxx/
*.hprof

# iOS (si jamais buildé sur Mac plus tard)
mobile/ios/build/
mobile/ios/Pods/
mobile/ios/*.xcworkspace
mobile/ios/*.xcuserstate

# Metro / Expo
mobile/.expo/
mobile/.expo-shared/
*.jsbundle

