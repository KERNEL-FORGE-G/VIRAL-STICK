# Viral Stick — Backend Environment
# Copie ce fichier en .env et remplis les clés

# ── IA Texte (pipeline : Gemini → Mistral → Puter → DeepSeek → OpenRouter) ──
GEMINI_API_KEY=votre_cle_gemini_ici
MISTRAL_API_KEY=votre_cle_mistral_ici
PUTER_KEY=votre_cle_puter_ici
PUTER_TOKEN=                         # alias accepté
DEEPSEEK_API_KEY=votre_cle_deepseek_ici
OPENROUTER_API_KEY=votre_cle_openrouter_ici
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── IA Audio (pipeline : Groq Whisper → Puter Whisper) ──
GROQ_API_KEY=votre_cle_groq_ici

# ── IA Image ──
# Pollinations.ai = primary (GRATUIT, sans clé)
# Puter = fallback image (nécessite PUTER_KEY)

# ── Puter modèles (optionnels) ──
PUTER_TEXT_MODEL=openai/gpt-oss-120b
PUTER_CHAT_MODEL=zai-org/GLM-4.5V
PUTER_MODEL=black-forest-labs/FLUX.1-schnell
PUTER_AUDIO_MODEL=openai/whisper-large-v3

# ── Serveur ───────────────────────────────────
PORT=3000
